<Window x:Class="MusicStore.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог" Height="400" Width="500">
    <Grid Margin="10">
        <TextBox x:Name="CatalogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        <Button Content="Назад" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="100" Height="30" Click="BackButton_Click" Margin="0,0,10,10"/>
    </Grid>
</Window>